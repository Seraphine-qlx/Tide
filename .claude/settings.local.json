{
  "permissions": {
    "allow": [
      "PowerShell(npm run *)",
      "PowerShell(npm install *)",
      "PowerShell($resp = Invoke-WebRequest -Uri \"http://localhost:3000\" -UseBasicParsing -TimeoutSec 60; \"STATUS: $\\($resp.StatusCode\\)\"; $resp.Content.Substring\\(0, [Math]::Min\\(800, $resp.Content.Length\\)\\))",
      "PowerShell($resp = Invoke-WebRequest -Uri \"http://localhost:3000/games/drift\" -UseBasicParsing -TimeoutSec 60; \"STATUS: $\\($resp.StatusCode\\)\")",
      "PowerShell(Test-Path *)",
      "PowerShell(winget install *)",
      "PowerShell(git config *)",
      "PowerShell(git *)",
      "PowerShell(git push *)",
      "PowerShell(npx tsc --noEmit 2>&1 | Select-Object -First 30)",
      "PowerShell(npx tsc --noEmit 2>&1)",
      "PowerShell($r1 = Invoke-WebRequest -Uri \"http://localhost:3000/games/periphery\" -UseBasicParsing -TimeoutSec 60; \"PERIPHERY: $\\($r1.StatusCode\\)\"; $r2 = Invoke-WebRequest -Uri \"http://localhost:3000/games/periphery/quiz\" -UseBasicParsing -TimeoutSec 60; \"QUIZ: $\\($r2.StatusCode\\)\")",
      "PowerShell($r = Invoke-WebRequest -Uri \"http://localhost:3000/games/periphery/quiz\" -UseBasicParsing -TimeoutSec 60; \"STATUS: $\\($r.StatusCode\\)\")",
      "PowerShell($r = Invoke-WebRequest -Uri \"http://localhost:3000/games/pulse\" -UseBasicParsing -TimeoutSec 60; \"PULSE: $\\($r.StatusCode\\)\")",
      "PowerShell(git status *)"
    ]
  }
}
